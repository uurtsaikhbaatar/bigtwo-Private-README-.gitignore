{
  "name": "bigtwo-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Big Two тоглоомын real-time сервер (WebSocket)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file-if-exists=.env --import tsx --test src/game.test.ts src/match.test.ts src/db.test.ts src/avatar.test.ts src/ranks.test.ts",
    "smoke": "node --import tsx src/smoke.ts",
    "bots": "node --import tsx src/bots.ts",
    "reports": "node --env-file-if-exists=.env --import tsx src/show-reports.ts",
    "db:init": "node --env-file-if-exists=.env --import tsx src/db-init.ts",
    "email:test": "node --env-file-if-exists=.env --import tsx src/email-test.ts",
    "live": "node --env-file-if-exists=.env --import tsx src/live-cli.ts",
    "tokens": "node --env-file-if-exists=.env --import tsx src/tokens-cli.ts"
  },
  "dependencies": {
    "pg": "^8.22.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
