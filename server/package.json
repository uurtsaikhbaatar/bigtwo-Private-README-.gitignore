{
  "name": "bigtwo-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Big Two тоглоомын real-time сервер (WebSocket)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/game.test.ts src/match.test.ts",
    "smoke": "node --import tsx src/smoke.ts",
    "bots": "node --import tsx src/bots.ts",
    "reports": "node --import tsx src/show-reports.ts"
  },
  "dependencies": {
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
