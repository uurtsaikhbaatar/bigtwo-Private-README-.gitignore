# Энэ файлыг `.env` нэрээр хуулж, утгуудаа бөглөнө.
# `.env` нь git-д ордоггүй — нууц утгууд repo-д хэзээ ч орохгүй.

# Neon (эсвэл ямар ч Postgres) холболтын мөр.
# Neon дээр: Connection string → Show password → Copy snippet
DATABASE_URL=postgresql://хэрэглэгч:нууц@хост.neon.tech/neondb?sslmode=require

# Алдааны мэдэгдлийг /reports-оор харах түлхүүр (интернэтэд гаргасан бол заавал).
# REPORT_KEY=өөрийн-нууц-түлхүүр

# Мэдэгдэл ирмэгц Discord/Slack руу шууд илгээх webhook (сонголтоор).
# REPORT_WEBHOOK=https://discord.com/api/webhooks/…
