# Энэ файлыг `.env` нэрээр хуулж, утгуудаа бөглөнө.
# `.env` нь git-д ордоггүй — нууц утгууд repo-д хэзээ ч орохгүй.

# Neon (эсвэл ямар ч Postgres) холболтын мөр.
# Neon дээр: Connection string → Show password → Copy snippet
DATABASE_URL=postgresql://хэрэглэгч:нууц@хост.neon.tech/neondb?sslmode=require

# Алдааны мэдэгдлийг /reports-оор харах түлхүүр (интернэтэд гаргасан бол заавал).
# REPORT_KEY=өөрийн-нууц-түлхүүр

# Мэдэгдэл ирмэгц Discord/Slack руу шууд илгээх webhook (сонголтоор).
# REPORT_WEBHOOK=https://discord.com/api/webhooks/…

# Имэйл илгээх. Тохируулаагүй бол код серверийн лог руу бичигдэнэ
# (үйлчилгээгүйгээр турших боломжтой хэвээр).
#
# ХАМГИЙН ХЯЛБАР — Gmail. Шинэ бүртгэл, SMS шаардлагагүй.
# EMAIL_APP_PASSWORD нь Google-ийн "App password" — ЖИНХЭНЭ нууц үг БИШ.
# myaccount.google.com/apppasswords дээрээс үүсгэнэ (2 алхамт баталгаа асаалттай байх).
# EMAIL_PROVIDER=gmail
# EMAIL_USER=тань@gmail.com
# EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Эсвэл API-тай үйлчилгээ:
# EMAIL_PROVIDER=brevo        # brevo | sendgrid | resend
# EMAIL_API_KEY=…
# EMAIL_FROM="Дай Ди <тань@жишээ.mn>"
