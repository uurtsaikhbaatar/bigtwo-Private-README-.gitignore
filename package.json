{
  "name": "bigtwo",
  "version": "0.1.0",
  "private": true,
  "description": "Дай Ди (Big Two) — найзуудтайгаа онлайнаар тоглох хөзрийн апп",
  "scripts": {
    "server": "npm --prefix server start",
    "app": "npm --prefix app start",
    "test": "npm --prefix server test",
    "games": "npm --prefix server run games --",
    "ads": "npm --prefix server run ads --",
    "live": "npm --prefix server run live --",
    "smoke": "npm --prefix server run smoke",
    "build:web": "npm --prefix app run build:web",
    "typecheck": "npm --prefix server run typecheck && npm --prefix app run typecheck",
    "setup": "npm --prefix server install && npm --prefix app install",
    "reports": "npm --prefix server run reports --",
    "db:init": "npm --prefix server run db:init",
    "email:test": "npm --prefix server run email:test --",
    "tokens": "npm --prefix server run tokens --"
  }
}
